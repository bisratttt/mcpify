{
  "name": "apimcp",
  "version": "0.1.0",
  "description": "Turn any API spec into an MCP server — on demand, without clogging your context",
  "type": "module",
  "bin": {
    "apimcp": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/mcp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "graphql": "^16.9.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.52.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
